using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace CafeManagement.Models
{
    public class Beverage
    {
        public int Id { get; set; }

        [Required(ErrorMessage = "Vui lòng nhập tên đồ uống")]
        [StringLength(150)]
        [Display(Name = "Tên đồ uống")]
        public string Name { get; set; } = string.Empty;

        [Required]
        [Column(TypeName = "decimal(18,2)")]
        [Range(0, double.MaxValue, ErrorMessage = "Giá phải >= 0")]
        [Display(Name = "Giá bán (VNĐ)")]
        public decimal Price { get; set; }

        [StringLength(500)]
        [Display(Name = "Mô tả")]
        public string? Description { get; set; }

        [Display(Name = "Ảnh (URL)")]
        public string? ImageUrl { get; set; }

        [Display(Name = "Còn bán")]
        public bool IsAvailable { get; set; } = true;

        [StringLength(100)]
        [Display(Name = "Loại đồ uống")]
        public string? BeverageType { get; set; } // Ví dụ: "Cà phê", "Trà", "Nước ép", "Smoothie"

        [Display(Name = "Nhiệt độ")]
        public int? Temperature { get; set; } // Ví dụ: 60 (°C) cho nóng, 5 (°C) cho lạnh

        [Display(Name = "Kích cỡ (ml)")]
        [Range(0, int.MaxValue)]
        public int? Size { get; set; } // Ví dụ: 250ml, 350ml, 500ml

        [Display(Name = "Có chứa đường")]
        public bool? HasSugar { get; set; }

        [Display(Name = "Ngày tạo")]
        public DateTime CreatedDate { get; set; } = DateTime.Now;

        [Display(Name = "Ngày cập nhật")]
        public DateTime? UpdatedDate { get; set; }

        [Display(Name = "Số lượng tồn")]
        [Range(0, int.MaxValue)]
        public int Stock { get; set; } = 0;
    }
}
