@using Quản_lý_quán_cafe.Models.ViewModels.RestaurantTable
@model RestaurantTableDetailViewModel

@{
    ViewData["Title"] = "Chi tiết bàn";
    ViewData["PageTitle"] = "Chi tiết bàn";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><a href='" + Url.Action("Index") + "'><i class='bi bi-grid-3x3'></i> Bàn</a></span><span class='breadcrumb-item'><i class='bi bi-info-circle'></i> Chi tiết</span>";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <p style="color: var(--text-light); margin: 0; font-size: 14px;">BrewPoint Cafe · Quản trị</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Chỉnh sửa
        </a>
        <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="card">
            <div class="card-header" style="border-bottom: 1px solid #e9ecef;">
                <h5 class="mb-0">Thông tin bàn</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <strong>Mã bàn:</strong>
                    </div>
                    <div class="col-sm-8">
                        <p>@Model.TableNumber</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <strong>Sức chứa:</strong>
                    </div>
                    <div class="col-sm-8">
                        <p>@Model.Capacity người</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <strong>Khu vực:</strong>
                    </div>
                    <div class="col-sm-8">
                        <p>@(string.IsNullOrEmpty(Model.Location) ? "-- Không xác định --" : Model.Location)</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <strong>Trạng thái:</strong>
                    </div>
                    <div class="col-sm-8">
                        <p>
                            @if (Model.TableStatus == "Available")
                            {
                                <span class="badge bg-success">Trống</span>
                            }
                            else if (Model.TableStatus == "Occupied")
                            {
                                <span class="badge bg-danger">Có khách</span>
                            }
                            else if (Model.TableStatus == "WaitingPayment")
                            {
                                <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                            }
                            else if (Model.TableStatus == "Maintenance")
                            {
                                <span class="badge bg-secondary">Bảo trì</span>
                            }
                        </p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <strong>Ngày tạo:</strong>
                    </div>
                    <div class="col-sm-8">
                        <p>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Lần sửa cuối:</strong>
                        </div>
                        <div class="col-sm-8">
                            <p>@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 mt-4">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
