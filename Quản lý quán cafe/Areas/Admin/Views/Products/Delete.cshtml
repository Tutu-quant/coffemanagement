@model ProductDetailViewModel

@{
    ViewData["Title"] = "Xóa sản phẩm";
    ViewData["PageTitle"] = "Xóa sản phẩm";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><a href='" + Url.Action("Index", "Products", new { area = "Admin" }) + "'><i class='bi bi-cup'></i> Sản phẩm</a></span><span class='breadcrumb-item'>Xóa</span>";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <a href="@Url.Action("Index")" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body" style="text-align: center; padding: 60px 40px;">
        <div style="margin-bottom: 24px;">
            <i class="bi bi-exclamation-circle" style="font-size: 64px; color: #dc3545;"></i>
        </div>

        <h3 style="color: var(--text-dark); margin-bottom: 12px;">Xác nhận xóa sản phẩm</h3>
        <p style="color: var(--text-light); margin-bottom: 24px;">
            Bạn có chắc muốn xóa sản phẩm <strong>@Model.Name</strong>? Hành động này không thể hoàn tác.
        </p>

        <div style="background-color: var(--cream); padding: 16px; border-radius: 8px; margin-bottom: 32px; text-align: left;">
            <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                <span style="font-weight: 600; color: var(--text-dark); min-width: 100px;">Tên:</span>
                <span style="color: var(--text-light);">@Model.Name</span>
            </div>
            <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                <span style="font-weight: 600; color: var(--text-dark); min-width: 100px;">Danh mục:</span>
                <span style="color: var(--text-light);">@Model.CategoryName</span>
            </div>
            <div style="display: flex; gap: 12px;">
                <span style="font-weight: 600; color: var(--text-dark); min-width: 100px;">Giá:</span>
                <span style="color: var(--text-light);">@Model.Price.ToString("N0")đ</span>
            </div>
        </div>

        <form method="post" asp-action="DeleteConfirmed" style="display: inline;">
            <input type="hidden" name="id" value="@Model.Id">

            <div style="display: flex; gap: 12px; justify-content: center;">
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xóa sản phẩm
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .btn-danger:hover {
        background-color: #c82333;
        border-color: #c82333;
    }
</style>

