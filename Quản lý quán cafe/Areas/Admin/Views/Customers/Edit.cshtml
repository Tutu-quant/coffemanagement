@using Quản_lý_quán_cafe.Models.ViewModels.Customer
@model CustomerEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa khách hàng";
    ViewData["PageTitle"] = "Chỉnh sửa";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><a href='" + Url.Action("Index") + "'><i class='bi bi-people'></i> Khách hàng</a></span><span class='breadcrumb-item'><i class='bi bi-pencil'></i> Chỉnh sửa</span>";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <p style="color: var(--text-light); margin: 0; font-size: 14px;">BrewPoint Cafe · Quản trị</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Chỉnh sửa thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Edit">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id">

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập họ tên">
                        <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại">
                        <span asp-validation-for="Phone" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email">
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ">
                        <span asp-validation-for="Address" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="RewardPoints" class="form-label"></label>
                                <input asp-for="RewardPoints" type="number" class="form-control" placeholder="0">
                                <span asp-validation-for="RewardPoints" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MembershipTier" class="form-label"></label>
                                <select asp-for="MembershipTier" class="form-select">
                                    <option value="Member">Member</option>
                                    <option value="Silver">Silver</option>
                                    <option value="Gold">Gold</option>
                                    <option value="Diamond">Diamond</option>
                                    <option value="VIP">VIP</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TotalSpent" class="form-label"></label>
                        <input asp-for="TotalSpent" type="number" step="0.01" class="form-control" placeholder="0">
                        <span asp-validation-for="TotalSpent" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input">
                        <label asp-for="IsActive" class="form-check-label">Hoạt động</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Cập nhật</button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary flex-grow-1">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Head {
    <link rel="stylesheet" href="~/css/customers.css" asp-append-version="true" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
