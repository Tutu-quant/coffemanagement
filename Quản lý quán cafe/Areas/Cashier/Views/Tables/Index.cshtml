@model List<dynamic>

@{
    ViewData["Title"] = "Quản lý bàn";
    ViewData["PageTitle"] = "Quản lý bàn";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><i class='bi bi-grid-3x3'></i> Bàn</span>";
}

<div class="page-header-cashier">
    <h1 class="page-title">🍽️ Quản lý bàn</h1>
</div>

<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i>
    <strong>Thông báo:</strong> Trang quản lý bàn đang phát triển. Vui lòng quay lại sau.
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>0</h3>
                <p class="text-muted">Bàn trống</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>0</h3>
                <p class="text-muted">Bàn đang sử dụng</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>0</h3>
                <p class="text-muted">Chờ thanh toán</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>0</h3>
                <p class="text-muted">Bàn được đặt trước</p>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0">Sơ đồ bàn</h5>
    </div>
    <div class="card-body">
        <div class="alert alert-secondary text-center py-4">
            <i class="bi bi-inbox"></i> Chưa có dữ liệu bàn
        </div>
    </div>
</div>
