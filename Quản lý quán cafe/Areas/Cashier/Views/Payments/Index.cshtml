@model List<dynamic>

@{
    ViewData["Title"] = "Thanh toán";
    ViewData["PageTitle"] = "Thanh toán";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><i class='bi bi-cash-coin'></i> Thanh toán</span>";
}

<div class="page-header-cashier">
    <h1 class="page-title">💳 Quản lý thanh toán</h1>
</div>

<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i>
    <strong>Thông báo:</strong> Trang quản lý thanh toán đang phát triển. Vui lòng quay lại sau.
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title">0 VND</h3>
                <p class="card-text text-muted">Đã thanh toán hôm nay</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title">0 VND</h3>
                <p class="card-text text-muted">Chờ thanh toán</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title">0</h3>
                <p class="card-text text-muted">Giao dịch hôm nay</p>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0">Lịch sử giao dịch</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Mã giao dịch</th>
                        <th>Loại thanh toán</th>
                        <th>Số tiền</th>
                        <th>Trạng thái</th>
                        <th>Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox"></i> Chưa có dữ liệu
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
