@model Quản_lý_quán_cafe.Areas.Cashier.ViewModels.POSViewModel

@{
    ViewData["Title"] = "POS - Bán hàng";
    Layout = "~/Areas/Cashier/Views/Shared/_POSLayout.cshtml";
}

@section Head {
    <link rel="stylesheet" href="~/css/pos.css" asp-append-version="true" />
}

<div class="pos-page">
    <div class="pos-wrapper">
        @await Html.PartialAsync("_TableList", Model.OpenTables)
        @await Html.PartialAsync("_OrderDetails", Model)
        @await Html.PartialAsync("_PaymentSummary", Model)
    </div>
</div>

@section Scripts {
    <script>
        let currentTableId = @(Model.CurrentTable?.TableID ?? 0);
        let currentCustomerId = @(Model.Customer?.CustomerID ?? 0);
        let currentPaymentMethod = 'cash';
        let orderItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderItems.Select(item => new { productId = item.ProductID, quantity = item.Quantity, notes = item.Notes })));

        function selectTable(tableId) {
            window.location.href = `/Cashier/POS?tableId=${tableId}`;
        }

        function addSelectedProduct() {
            const select = document.getElementById('productSelect');
            const productId = Number(select.value);
            if (!productId) return alert('Vui lòng chọn món');

            const existingItem = orderItems.find(item => item.productId === productId);
            if (existingItem) existingItem.quantity++;
            else orderItems.push({ productId, quantity: 1, notes: null });
            saveOrder();
        }

        function changeQuantity(orderDetailId, delta) {
            const itemIndex = [...document.querySelectorAll('.order-item')]
                .findIndex(element => element.dataset.itemId == orderDetailId);
            if (itemIndex < 0) return;

            orderItems[itemIndex].quantity += delta;
            if (orderItems[itemIndex].quantity < 1) orderItems.splice(itemIndex, 1);
            if (!orderItems.length) return alert('Đơn hàng cần có ít nhất một món');
            saveOrder();
        }

        function increaseQty(orderDetailId) { changeQuantity(orderDetailId, 1); }
        function decreaseQty(orderDetailId) { changeQuantity(orderDetailId, -1); }

        function removeItem(orderDetailId) {
            if (!confirm('Xóa món này?')) return;
            const itemIndex = [...document.querySelectorAll('.order-item')]
                .findIndex(element => element.dataset.itemId == orderDetailId);
            if (itemIndex < 0) return;
            orderItems.splice(itemIndex, 1);
            if (!orderItems.length) return alert('Đơn hàng cần có ít nhất một món');
            saveOrder();
        }

        function saveOrder() {
            if (!currentTableId || !orderItems.length) return;
            fetch('/Cashier/POS/SaveOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tableId: currentTableId,
                    customerId: currentCustomerId || null,
                    notes: document.getElementById('orderNotes')?.value || null,
                    items: orderItems
                })
            }).then(async response => {
                const data = await response.json();
                if (!response.ok || !data.success) throw new Error(data.message || 'Không thể lưu đơn hàng');
                location.reload();
            }).catch(error => alert(error.message));
        }

        function searchCustomer() {
            const phone = document.getElementById('customerPhone').value;
            fetch(`/Cashier/POS/SearchCustomer?phone=${encodeURIComponent(phone)}`)
                .then(r => r.json())
                .then(data => {
                    if (!data.found) return alert('Không tìm thấy khách hàng');
                    currentCustomerId = data.customer.customerID;
                    saveOrder();
                });
        }

        function selectPaymentMethod(method) {
            currentPaymentMethod = method;
            document.querySelectorAll('.method-btn').forEach(button => button.classList.remove('active'));
            event.target.closest('.method-btn').classList.add('active');
        }

        function proceedCheckout() {
            if (!currentTableId) return alert('Vui lòng chọn bàn');
            const paidAmount = Number(document.getElementById('paidAmount').value) * 1000;
            fetch('/Cashier/POS/Checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tableId: currentTableId, paymentMethod: currentPaymentMethod, paidAmount })
            }).then(async response => {
                const data = await response.json();
                if (!response.ok || !data.success) throw new Error(data.message || 'Không thể thanh toán');
                alert(`Thanh toán thành công. Tiền thừa: ${data.changeAmount.toLocaleString('vi-VN')}đ`);
                window.location.href = '/Cashier/POS';
            }).catch(error => alert(error.message));
        }

        function closeTable() { window.location.href = '/Cashier/POS'; }
    </script>
}
