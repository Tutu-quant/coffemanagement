@model Quản_lý_quán_cafe.Areas.Cashier.ViewModels.POSViewModel

<!-- Cột giữa: Chi tiết đơn hàng -->
<div class="pos-main">
    @if (Model.CurrentTable != null)
    {
        <!-- Header bàn -->
        <div class="order-header">
            <div>
                <h2>@Model.CurrentTable.TableName — @Model.CurrentTable.OrderCode</h2>
                <p class="text-muted">@Model.OrderItems.Count() món</p>
            </div>
            <button class="btn-close" onclick="closeTable()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Danh sách món -->
        <div class="order-items-section">
            <div class="d-flex gap-2 mb-3">
                <select id="productSelect" class="form-select form-select-sm" aria-label="Chọn món">
                    <option value="">Chọn món để thêm...</option>
                    @foreach (var product in Model.AvailableProducts)
                    {
                        <option value="@product.ProductID" data-price="@product.Price">@product.ProductName — @product.Price.ToString("N0")đ</option>
                    }
                </select>
                <button type="button" class="btn btn-sm btn-primary text-nowrap" onclick="addSelectedProduct()">Thêm món</button>
            </div>
            <div class="section-header">
                <div class="col-name">MÓN</div>
                <div class="col-qty">SL</div>
                <div class="col-price">GIÁ</div>
            </div>

            <div class="order-items" id="orderItems">
                @if (!Model.OrderItems.Any())
                {
                    <div class="empty-order">
                        <p>Chưa có món nào</p>
                    </div>
                }
                else
                {
                    @foreach (var item in Model.OrderItems)
                    {
                        <div class="order-item" data-item-id="@item.OrderDetailID">
                            <div class="item-main">
                                <div class="item-info">
                                    <div class="item-name">@item.ProductName</div>
                                    <div class="item-size">Cỡ @item.Size</div>
                                    @if (!string.IsNullOrEmpty(item.Notes))
                                    {
                                        <div class="item-notes">@item.Notes</div>
                                    }
                                </div>
                                <div class="item-controls">
                                    <button class="qty-btn" onclick="decreaseQty(@item.OrderDetailID)">−</button>
                                    <span class="qty">@item.Quantity</span>
                                    <button class="qty-btn" onclick="increaseQty(@item.OrderDetailID)">+</button>
                                </div>
                                <div class="item-price">@item.Total.ToString("N0")đ</div>
                                <button class="btn-remove" onclick="removeItem(@item.OrderDetailID)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Thông tin khách hàng -->
        <div class="customer-section">
            <div class="section-header">
                <h3>Thông tin khách hàng</h3>
            </div>
            @if (Model.Customer?.CustomerID.HasValue == true)
            {
                <div class="customer-info">
                    <div class="customer-badge">⭐ @Model.Customer.MembershipTier</div>
                    <div class="customer-name">@Model.Customer.Name</div>
                    <div class="customer-phone">@Model.Customer.Phone</div>
                    <div class="customer-points">
                        <i class="bi bi-gift"></i> @Model.Customer.RewardPoints điểm
                    </div>
                </div>
            }
            else
            {
                <div class="search-customer">
                    <input type="text" class="form-control" placeholder="☎ Số điện thoại (để tích diểm)" id="customerPhone" />
                    <button class="btn btn-sm btn-outline-secondary" onclick="searchCustomer()">Tìm</button>
                </div>
            }
        </div>

        <!-- Ghi chú & Giảm giá -->
        <div class="notes-discount-section">
            <!-- Ghi chú đơn hàng -->
            <div class="notes-part">
                <label>Ghi chú:</label>
                <textarea class="form-control form-control-sm" placeholder="Ghi chú cho đơn hàng..." rows="2" id="orderNotes">@Model.Notes</textarea>
            </div>

            <!-- Giảm giá -->
            <div class="discount-part">
                <label>Giảm giá:</label>
                <div class="discount-buttons">
                    <button class="discount-btn active" onclick="setDiscountType('none')">Không</button>
                    <button class="discount-btn" onclick="setDiscountType('percent')">% Giảm</button>
                    <button class="discount-btn" onclick="setDiscountType('fixed')">Số tiền</button>
                </div>
                <input type="number" class="form-control form-control-sm" placeholder="Nhập giá trị" id="discountValue" style="margin-top: 0.5rem;" onchange="calculateTotal()" />
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>Vui lòng chọn bàn từ danh sách</p>
        </div>
    }
</div>
