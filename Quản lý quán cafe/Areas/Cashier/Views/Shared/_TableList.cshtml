@model List<POSTableViewModel>

<!-- Cột trái: Danh sách bàn -->
<div class="pos-sidebar">
    <!-- Logo -->
    <div class="pos-logo">
        <i class="bi bi-cup-hot"></i>
        <div>
            <div class="logo-brand">BrewPoint POS</div>
            <div class="logo-tagline">Quản lý bàn</div>
        </div>
    </div>

    <!-- Tìm kiếm bàn -->
    <div class="pos-search">
        <input type="text" class="form-control" placeholder="🔍 Tìm bàn..." id="searchTable" />
    </div>

    <!-- Danh sách bàn mở -->
    <div class="tables-list">
        @if (Model == null || Model.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>Không có bàn nào mở</p>
            </div>
        }
        else
        {
            @foreach (var table in Model)
            {
                <div class="table-item @table.Status" data-table-id="@table.TableID" onclick="selectTable(@table.TableID)">
                    <div class="table-header">
                        <div class="table-info">
                            <div class="table-name">@table.TableName</div>
                            <div class="table-code">@table.OrderCode - @table.ItemCount món</div>
                        </div>
                        <div class="table-price">@table.TotalAmount.ToString("N0")đ</div>
                    </div>
                    @if (!string.IsNullOrEmpty(table.StatusBadge))
                    {
                        <div class="table-badge">@table.StatusBadge</div>
                    }
                </div>
            }
        }
    </div>

    <!-- Nút quay lại -->
    <div class="pos-footer">
        <a href="@Url.Action("Index", "Dashboard", new { area = "Cashier" })" class="btn-back">
            <i class="bi bi-chevron-left"></i> Nhân viên
        </a>
    </div>
</div>
