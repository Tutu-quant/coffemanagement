@using Quản_lý_quán_cafe.Models.ViewModels.Account
@model RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BrewPoint</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="login-wrapper">
        <!-- Left Side -->
        <div class="login-left">
            <div class="login-logo">
                <div class="login-logo-icon">
                    <i class="bi bi-cup-hot"></i>
                </div>
                <div class="login-logo-text">BrewPoint</div>
            </div>

            <div class="login-hero">
                <div class="login-hero-image">
                    <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=500&h=400&fit=crop" alt="Coffee" />
                </div>

                <div class="login-hero-text">
                    <h1>
                        Quán của bạn,<br>
                        <span>Quản lý hoàn hảo.</span>
                    </h1>
                    <p class="login-hero-description">
                        Đặt hàng QR, màn hình bếp theo thời gian thực, thu ngân POS và phân tích — tất cả trong một nơi.
                    </p>
                </div>

                <div class="login-features">
                    <div class="feature-pill">
                        <i class="bi bi-qr-code"></i> Đặt hàng QR
                    </div>
                    <div class="feature-pill">
                        <i class="bi bi-lightning-fill"></i> Theo dõi trực tiếp
                    </div>
                    <div class="feature-pill">
                        <i class="bi bi-gift"></i> Tích điểm
                    </div>
                    <div class="feature-pill">
                        <i class="bi bi-graph-up"></i> Phân tích
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="login-right">
            <div class="login-container">
                <div class="login-header">
                    <h2>Đăng ký</h2>
                    <h1>Tạo tài khoản mới</h1>
                </div>

                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" asp-action="Register" id="registerForm">
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">Họ và tên</label>
                        <input type="text" asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="form-error-message"></span>
                    </div>

                    <!-- Username -->
                    <div class="form-group">
                        <label asp-for="Username" class="form-label">Tên đăng nhập</label>
                        <input type="text" asp-for="Username" class="form-control" placeholder="Chọn tên đăng nhập" />
                        <span asp-validation-for="Username" class="form-error-message"></span>
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="your@email.com" />
                        <span asp-validation-for="Email" class="form-error-message"></span>
                    </div>

                    <!-- Phone -->
                    <div class="form-group">
                        <label asp-for="Phone" class="form-label">Số điện thoại (tuỳ chọn)</label>
                        <input type="tel" asp-for="Phone" class="form-control" placeholder="0912345678" />
                        <span asp-validation-for="Phone" class="form-error-message"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                        <div class="password-input-group">
                            <input type="password" id="password" asp-for="Password" class="form-control" placeholder="Tối thiểu 8 ký tự" />
                            <button type="button" class="password-toggle" onclick="togglePasswordField('password')">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="form-error-message"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu</label>
                        <div class="password-input-group">
                            <input type="password" id="confirmPassword" asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                            <button type="button" class="password-toggle" onclick="togglePasswordField('confirmPassword')">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="form-error-message"></span>
                    </div>

                    <!-- Register Button -->
                    <button type="submit" class="login-btn">Đăng ký</button>
                </form>

                <!-- Login Link -->
                <div class="register-section">
                    <p class="register-text">Đã có tài khoản?</p>
                    <a href="@Url.Action("Login", "Account")" class="register-link">
                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập ngay
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePasswordField(fieldId) {
            const field = document.getElementById(fieldId);
            const button = event.target.closest('.password-toggle');
            const icon = button.querySelector('i');

            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Prevent form submission on Enter in password toggle button
        document.querySelectorAll('.password-toggle').forEach(btn => {
            btn.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>
