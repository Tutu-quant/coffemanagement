@using Quản_lý_quán_cafe.Models.ViewModels.Customer
@model CustomerDetailViewModel

@{
    ViewData["Title"] = "Chi tiết khách hàng";
    ViewData["PageTitle"] = "Chi tiết khách hàng";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><a href='" + Url.Action("Index") + "'><i class='bi bi-people'></i> Khách hàng</a></span><span class='breadcrumb-item'><i class='bi bi-info-circle'></i> Chi tiết</span>";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <p style="color: var(--text-light); margin: 0; font-size: 14px;">BrewPoint Cafe · Quản trị</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Quay lại
        </a>
        <a href="@Url.Action("Edit", new { id = Model?.Id })" class="btn btn-warning">
            <i class="bi bi-pencil"></i>
            Chỉnh sửa
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Basic Information Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person"></i> Thông tin cá nhân
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-4">
                        <div class="avatar-circle-large mb-2">
                            @Model?.AvatarInitials
                        </div>
                        <p class="text-muted">@Model?.Name</p>
                    </div>
                    <div class="col-md-8">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="text-muted small">Họ tên</label>
                                <p class="mb-0">@Model?.Name</p>
                            </div>
                            <div class="col-6">
                                <label class="text-muted small">Số điện thoại</label>
                                <p class="mb-0">
                                    <i class="bi bi-telephone"></i>
                                    @Model?.Phone
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="text-muted small">Email</label>
                                <p class="mb-0">@Model?.Email</p>
                            </div>
                            <div class="col-6">
                                <label class="text-muted small">Địa chỉ</label>
                                <p class="mb-0">@Model?.Address</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="text-muted small">Ngày tham gia</label>
                                <p class="mb-0">@Model?.CreatedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="col-6">
                                <label class="text-muted small">Trạng thái</label>
                                <p class="mb-0">
                                    @if (Model?.IsActive == true)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngừng hoạt động</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Orders Card -->
        @if (Model?.RecentOrders?.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-bag"></i> 5 đơn hàng gần nhất
                    </h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày mua</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>#@order.Id</strong></td>
                                    <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@order.TotalAmount.ToString("N0")₫</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@order.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- Sidebar Statistics -->
    <div class="col-lg-4">
        <!-- Membership Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star"></i> Hạng thành viên
                </h5>
            </div>
            <div class="card-body text-center">
                @{
                    var tierClass = Model?.MembershipTier switch
                    {
                        "VIP" => "badge-vip",
                        "Diamond" => "badge-diamond",
                        "Gold" => "badge-gold",
                        "Silver" => "badge-silver",
                        _ => "badge-member"
                    };
                }
                <span class="badge @tierClass" style="font-size: 16px; padding: 8px 12px;">
                    @Model?.MembershipTier
                </span>
            </div>
        </div>

        <!-- Reward Points Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-gift"></i> Điểm tích lũy
                </h5>
            </div>
            <div class="card-body">
                <div class="text-center">
                    <p class="text-muted small mb-1">Tổng điểm</p>
                    <p style="font-size: 28px; font-weight: bold; color: #FF8C42; margin: 0;">
                        @Model?.RewardPoints.ToString("N0")
                    </p>
                </div>
            </div>
        </div>

        <!-- Total Spent Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-cash"></i> Tổng chi tiêu
                </h5>
            </div>
            <div class="card-body">
                <div class="text-center">
                    <p class="text-muted small mb-1">Tất cả đơn hàng</p>
                    <p style="font-size: 24px; font-weight: bold; color: #4CAF50; margin: 0;">
                        @Model?.TotalSpent.ToString("N0")₫
                    </p>
                </div>
            </div>
        </div>

        <!-- Number of Orders Card -->
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-graph-up"></i> Số đơn hàng
                </h5>
            </div>
            <div class="card-body">
                <div class="text-center">
                    <p class="text-muted small mb-1">Tổng cộng</p>
                    <p style="font-size: 28px; font-weight: bold; color: #667EEA; margin: 0;">
                        @Model?.RecentOrders?.Count ?? 0
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Head {
    <link rel="stylesheet" href="~/css/customers.css" asp-append-version="true" />
}
