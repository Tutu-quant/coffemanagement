@model ProductDetailViewModel

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    ViewData["PageTitle"] = "Chi tiết sản phẩm";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><a href='" + Url.Action("Index", "Products", new { area = "Admin" }) + "'><i class='bi bi-cup'></i> Sản phẩm</a></span><span class='breadcrumb-item'>Chi tiết</span>";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
    <div style="display: flex; gap: 12px;">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Chỉnh sửa
        </a>
        <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="product-image-container">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="/uploads/products/@Model.ImageUrl" alt="@Model.Name" class="product-image-detail">
                    }
                    else
                    {
                        <div class="product-image-placeholder">
                            <i class="bi bi-cup-hot"></i>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-8">
                <div class="product-details">
                    <h2 class="product-name">@Model.Name</h2>

                    <div class="product-meta">
                        <div class="meta-item">
                            <span class="meta-label">Danh mục:</span>
                            <span class="meta-value">@Model.CategoryName</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Giá:</span>
                            <span class="meta-value price">@Model.Price.ToString("N0")đ</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Đã bán:</span>
                            <span class="meta-value"><i class="bi bi-star-fill" style="color: #ffc107;"></i> @Model.SalesCount</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Trạng thái:</span>
                            @if (Model.IsAvailable)
                            {
                                <span class="badge badge-success">
                                    <i class="bi bi-check-circle"></i> Đang bán
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-warning">
                                    <i class="bi bi-exclamation-circle"></i> Tạm dừng
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="meta-item">
                                <span class="meta-label">Mô tả:</span>
                                <div class="meta-value description-text">
                                    @Model.Description
                                </div>
                            </div>
                        }

                        <div class="meta-item">
                            <span class="meta-label">Ngày tạo:</span>
                            <span class="meta-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>

                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div class="meta-item">
                                <span class="meta-label">Cập nhật lần cuối:</span>
                                <span class="meta-value">@Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .product-image-container {
        width: 100%;
        background-color: var(--cream);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        aspect-ratio: 1;
    }

    .product-image-detail {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--coffee-light), var(--coffee-brown));
        color: white;
        font-size: 64px;
    }

    .product-details {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .product-name {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0;
        line-height: 1.2;
    }

    .product-meta {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .meta-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .meta-item:last-child {
        border-bottom: none;
    }

    .meta-label {
        font-weight: 600;
        color: var(--text-dark);
        min-width: 120px;
    }

    .meta-value {
        color: var(--text-light);
        flex: 1;
    }

    .meta-value.price {
        font-weight: 700;
        color: var(--coffee-brown);
        font-size: 18px;
    }

    .description-text {
        white-space: pre-wrap;
        line-height: 1.6;
    }

    .badge-success {
        background-color: #4CAF50;
        color: white;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 14px;
    }

    .badge-warning {
        background-color: #FFC107;
        color: #333;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 14px;
    }
</style>

