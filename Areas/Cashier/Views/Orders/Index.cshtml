@model List<dynamic>

@{
    ViewData["Title"] = "Đơn hàng";
    ViewData["PageTitle"] = "Đơn hàng";
    ViewData["PageBreadcrumb"] = "<span class='breadcrumb-item'><i class='bi bi-receipt'></i> Đơn hàng</span>";
}

<div class="page-header-cashier">
    <h1 class="page-title">📋 Quản lý đơn hàng</h1>
</div>

<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i>
    <strong>Thông báo:</strong> Trang quản lý đơn hàng đang phát triển. Vui lòng quay lại sau.
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Bàn</th>
                        <th>Trạng thái</th>
                        <th>Tổng tiền</th>
                        <th>Thời gian</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox"></i> Chưa có dữ liệu
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
