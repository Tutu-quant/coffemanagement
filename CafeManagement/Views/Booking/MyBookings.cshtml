@model IEnumerable<Booking>
@{
    ViewData["Title"] = "Đặt bàn của tôi";
}

<h2 class="mb-4">Đặt bàn của tôi</h2>

@if (!Model.Any())
{
    <p class="text-muted">Bạn chưa có đặt bàn nào. <a asp-action="Create">Đặt bàn ngay</a></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white shadow-sm">
            <thead>
                <tr>
                    <th>Bàn</th>
                    <th>Thời gian</th>
                    <th>Số ghế</th>
                    <th>Tiền cọc</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.Table?.TableName</td>
                        <td>@b.BookingTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@b.NumberOfGuests</td>
                        <td>@b.DepositAmount.ToString("N0") VNĐ</td>
                        <td>
                            @switch (b.Status)
                            {
                                case BookingStatus.ChoXacNhan:
                                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                    break;
                                case BookingStatus.DaXacNhan:
                                    <span class="badge bg-success">Đã xác nhận</span>
                                    break;
                                case BookingStatus.DaHuy:
                                    <span class="badge bg-secondary">Đã huỷ</span>
                                    break;
                                case BookingStatus.HoanThanh:
                                    <span class="badge bg-primary">Hoàn thành</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (b.Status == BookingStatus.ChoXacNhan || b.Status == BookingStatus.DaXacNhan)
                            {
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post" onsubmit="return confirm('Bạn chắc chắn muốn huỷ đặt bàn này?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Huỷ</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
