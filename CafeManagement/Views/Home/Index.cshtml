@{
    ViewData["Title"] = "Trang chủ";
}

<div class="p-5 mb-4 bg-dark text-white rounded-4">
    <h1 class="display-5 fw-bold">☕ Chào mừng đến với Cafe Management</h1>
    <p class="col-md-8 fs-5">Đặt bàn, đặt ghế trước thật dễ dàng. Thưởng thức thực đơn đa dạng của chúng tôi.</p>
    <a class="btn btn-primary btn-lg mt-2" asp-controller="Booking" asp-action="Create">Đặt bàn ngay</a>
    <a class="btn btn-outline-light btn-lg mt-2" asp-controller="Menu" asp-action="Index">Xem thực đơn</a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm text-center p-3">
            <h2>@ViewBag.TotalTables</h2>
            <p class="text-muted mb-0">Tổng số bàn</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm text-center p-3">
            <h2 class="text-success">@ViewBag.AvailableTables</h2>
            <p class="text-muted mb-0">Bàn trống hiện tại</p>
        </div>
    </div>
</div>

<h3 class="mb-3">Món nổi bật</h3>
<div class="row g-3">
    @foreach (var p in (IEnumerable<Product>)ViewBag.FeaturedProducts)
    {
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@p.Name</h5>
                    <p class="text-muted small mb-1">@p.Category?.Name</p>
                    <p class="fw-bold text-primary">@p.Price.ToString("N0") VNĐ</p>
                </div>
            </div>
        </div>
    }
</div>
