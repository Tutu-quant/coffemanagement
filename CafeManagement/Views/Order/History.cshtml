@model IEnumerable<Order>
@{
    ViewData["Title"] = "Lịch sử hoá đơn";
}

<h2 class="mb-4">Lịch sử hoá đơn đã thanh toán</h2>

<form method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <input type="date" name="from" class="form-control" value="@(ViewBag.From as DateTime? != null ? ((DateTime)ViewBag.From).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="col-auto">
        <input type="date" name="to" class="form-control" value="@(ViewBag.To as DateTime? != null ? ((DateTime)ViewBag.To).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">Lọc</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover bg-white shadow-sm">
        <thead>
            <tr><th>#</th><th>Bàn</th><th>Thanh toán lúc</th><th>Phương thức</th><th>Tổng tiền</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.Id</td>
                    <td>@o.Table?.TableName</td>
                    <td>@o.PaidAt?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@o.PaymentMethod</td>
                    <td>@o.TotalAmount.ToString("N0") VNĐ</td>
                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Invoice" asp-route-id="@o.Id">Xem hoá đơn</a></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-3">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>
