@model Order
@{
    ViewData["Title"] = "Hoá đơn #" + Model.Id;
    Layout = "_Layout";
}

<div class="card shadow-sm mx-auto" style="max-width:600px;">
    <div class="card-body">
        <div class="text-center mb-3">
            <h3>☕ Cafe Management</h3>
            <p class="text-muted mb-0">HOÁ ĐƠN THANH TOÁN</p>
            <p class="text-muted small">Số hoá đơn: #@Model.Id</p>
        </div>
        <hr />
        <p><strong>Bàn:</strong> @Model.Table?.TableName</p>
        <p><strong>Nhân viên:</strong> @Model.Staff?.FullName</p>
        <p><strong>Thời gian thanh toán:</strong> @Model.PaidAt?.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Phương thức:</strong> @Model.PaymentMethod</p>
        <hr />
        <table class="table">
            <thead><tr><th>Món</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
            <tbody>
                @foreach (var d in Model.OrderDetails)
                {
                    <tr>
                        <td>@d.Product?.Name</td>
                        <td>@d.Quantity</td>
                        <td>@d.UnitPrice.ToString("N0")</td>
                        <td>@d.SubTotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
        <hr />
        <p class="d-flex justify-content-between"><span>Tiền món</span><span>@Model.SubTotal.ToString("N0") VNĐ</span></p>
        @if (Model.Booking != null)
        {
            <p class="d-flex justify-content-between text-success"><span>Trừ tiền cọc</span><span>- @Model.DepositApplied.ToString("N0") VNĐ</span></p>
        }
        @if (Model.DiscountAmount > 0)
        {
            <p class="d-flex justify-content-between text-success"><span>Giảm giá</span><span>- @Model.DiscountAmount.ToString("N0") VNĐ</span></p>
        }
        <h4 class="d-flex justify-content-between"><span>Tổng cộng</span><span class="text-primary">@Model.TotalAmount.ToString("N0") VNĐ</span></h4>
        <p class="text-center text-muted mt-4">Cảm ơn quý khách và hẹn gặp lại!</p>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary w-100" onclick="window.print()">In hoá đơn</button>
            <a class="btn btn-primary w-100" asp-action="Index">Về sơ đồ bàn</a>
        </div>
    </div>
</div>
