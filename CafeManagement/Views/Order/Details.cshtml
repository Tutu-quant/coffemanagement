@model Order
@{
    ViewData["Title"] = "Chi tiết order - " + Model.Table?.TableName;
    var products = (IEnumerable<Product>)ViewBag.Products;
}

<h2 class="mb-3">Order bàn: @Model.Table?.TableName</h2>
<p class="text-muted">Mở lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm mb-3">
            <div class="card-header">Thêm món</div>
            <div class="card-body">
                <form asp-action="AddItem" method="post" class="row g-2">
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <div class="col-7">
                        <select name="productId" class="form-select" required>
                            <option value="">-- Chọn món --</option>
                            @foreach (var p in products)
                            {
                                <option value="@p.Id">@p.Name - @p.Price.ToString("N0") VNĐ</option>
                            }
                        </select>
                    </div>
                    <div class="col-3">
                        <input type="number" name="quantity" value="1" min="1" class="form-control" />
                    </div>
                    <div class="col-2">
                        <button class="btn btn-primary w-100">Thêm</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">Danh sách món đã gọi</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr><th>Món</th><th>Đơn giá</th><th style="width:120px">SL</th><th>Thành tiền</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.OrderDetails)
                        {
                            <tr>
                                <td>@d.Product?.Name</td>
                                <td>@d.UnitPrice.ToString("N0")</td>
                                <td>
                                    <form asp-action="UpdateItem" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="detailId" value="@d.Id" />
                                        <input type="number" name="quantity" value="@d.Quantity" min="0" class="form-control form-control-sm" style="width:70px" />
                                        <button class="btn btn-sm btn-outline-secondary">Cập nhật</button>
                                    </form>
                                </td>
                                <td>@d.SubTotal.ToString("N0")</td>
                                <td>
                                    <form asp-action="RemoveItem" method="post">
                                        <input type="hidden" name="detailId" value="@d.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Xoá</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.OrderDetails.Any())
                        {
                            <tr><td colspan="5" class="text-muted text-center py-3">Chưa có món nào</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm bg-light">
            <div class="card-body">
                <h5>Tóm tắt hoá đơn</h5>
                <ul class="list-unstyled">
                    <li class="d-flex justify-content-between"><span>Tiền món</span><span>@Model.SubTotal.ToString("N0") VNĐ</span></li>
                    @if (Model.Booking != null)
                    {
                        <li class="d-flex justify-content-between text-success"><span>Trừ tiền cọc đã đặt</span><span>- @Model.DepositApplied.ToString("N0") VNĐ</span></li>
                    }
                </ul>
                <hr />
                <h4 class="d-flex justify-content-between">
                    <span>Tổng cộng</span>
                    <span class="text-primary">@Model.TotalAmount.ToString("N0") VNĐ</span>
                </h4>
                @if (Model.Status == OrderStatus.DangMo)
                {
                    <a class="btn btn-success w-100 mt-3" asp-action="Checkout" asp-route-id="@Model.Id">Thanh toán</a>
                }
                else
                {
                    <a class="btn btn-outline-primary w-100 mt-3" asp-action="Invoice" asp-route-id="@Model.Id">Xem hoá đơn</a>
                }
                <a class="btn btn-outline-secondary w-100 mt-2" asp-action="Index">Quay lại sơ đồ bàn</a>
            </div>
        </div>
    </div>
</div>
