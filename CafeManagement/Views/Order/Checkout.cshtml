@model Order
@{
    ViewData["Title"] = "Thanh toán";
}

<h2 class="mb-4">Thanh toán - @Model.Table?.TableName</h2>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header">Chi tiết hoá đơn</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead><tr><th>Món</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
                    <tbody>
                        @foreach (var d in Model.OrderDetails)
                        {
                            <tr>
                                <td>@d.Product?.Name</td>
                                <td>@d.Quantity</td>
                                <td>@d.UnitPrice.ToString("N0")</td>
                                <td>@d.SubTotal.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Checkout" asp-route-id="@Model.Id" method="post">
                    <p class="d-flex justify-content-between"><span>Tiền món</span><span>@Model.SubTotal.ToString("N0") VNĐ</span></p>
                    @if (Model.Booking != null)
                    {
                        <p class="d-flex justify-content-between text-success"><span>Tiền cọc đã đặt</span><span>- @Model.DepositApplied.ToString("N0") VNĐ</span></p>
                    }
                    <div class="mb-3">
                        <label class="form-label">Giảm giá thêm (nếu có, VNĐ)</label>
                        <input type="number" name="discountAmount" value="0" min="0" class="form-control" id="discountInput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phương thức thanh toán</label>
                        <select name="paymentMethod" class="form-select">
                            <option>Tiền mặt</option>
                            <option>Chuyển khoản</option>
                            <option>Thẻ</option>
                            <option>Ví điện tử</option>
                        </select>
                    </div>
                    <hr />
                    <h4 class="d-flex justify-content-between">
                        <span>Tổng tiền</span>
                        <span class="text-primary" id="finalTotal">@Model.TotalAmount.ToString("N0") VNĐ</span>
                    </h4>
                    <button type="submit" class="btn btn-success w-100 mt-3" onclick="return confirm('Xác nhận thanh toán?');">Xác nhận thanh toán</button>
                    <a class="btn btn-outline-secondary w-100 mt-2" asp-action="Details" asp-route-id="@Model.Id">Quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const subTotal = @Model.SubTotal;
        const depositApplied = @Model.DepositApplied;
        const discountInput = document.getElementById('discountInput');
        const finalTotalEl = document.getElementById('finalTotal');
        discountInput.addEventListener('input', () => {
            const discount = parseFloat(discountInput.value) || 0;
            let total = subTotal - depositApplied - discount;
            if (total < 0) total = 0;
            finalTotalEl.textContent = total.toLocaleString('vi-VN') + ' VNĐ';
        });
    </script>
}
