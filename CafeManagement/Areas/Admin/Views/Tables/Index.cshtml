@model IEnumerable<RestaurantTable>
@{
    ViewData["Title"] = "Bàn / Ghế";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý bàn / ghế</h2>
    <a class="btn btn-primary" asp-action="Create">+ Thêm bàn</a>
</div>

<table class="table table-hover bg-white shadow-sm align-middle">
    <thead><tr><th>Tên bàn</th><th>Số ghế</th><th>Khu vực</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.TableName</td>
                <td>@t.Capacity</td>
                <td>@t.Location</td>
                <td><span class="table-status-@t.Status">@t.Status</span></td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@t.Id">Sửa</a>
                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline" onsubmit="return confirm('Xoá bàn này?');">
                        <button class="btn btn-sm btn-outline-danger">Xoá</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
