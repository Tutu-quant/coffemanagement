@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<h2 class="mb-4">Tổng quan quản trị</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Doanh thu hôm nay</p>
            <h4 class="text-success">@(((decimal)ViewBag.RevenueToday).ToString("N0")) VNĐ</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Doanh thu tháng này</p>
            <h4 class="text-success">@(((decimal)ViewBag.RevenueMonth).ToString("N0")) VNĐ</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Hoá đơn hôm nay</p>
            <h4>@ViewBag.OrdersTodayCount</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Đặt bàn chờ xác nhận</p>
            <h4 class="text-warning">@ViewBag.PendingBookings</h4>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Tổng số bàn</p>
            <h4>@ViewBag.TotalTables</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Bàn trống</p>
            <h4 class="text-success">@ViewBag.AvailableTables</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Tổng số món</p>
            <h4>@ViewBag.TotalProducts</h4>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card shadow-sm text-center p-3">
            <p class="text-muted mb-1">Tổng số người dùng</p>
            <h4>@ViewBag.TotalUsers</h4>
        </div>
    </div>
</div>
