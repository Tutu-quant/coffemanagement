@model IEnumerable<Product>
@{
    ViewData["Title"] = "Món ăn / Thức uống";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Món ăn / Thức uống</h2>
    <a class="btn btn-primary" asp-action="Create">+ Thêm món</a>
</div>

<table class="table table-hover bg-white shadow-sm align-middle">
    <thead><tr><th>Tên món</th><th>Danh mục</th><th>Giá</th><th>Còn bán</th><th></th></tr></thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Category?.Name</td>
                <td>@p.Price.ToString("N0") VNĐ</td>
                <td>
                    @if (p.IsAvailable)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ngừng bán</span>
                    }
                </td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Sửa</a>
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Xoá món này?');">
                        <button class="btn btn-sm btn-outline-danger">Xoá</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
