@using CafeManagement.Areas.Admin.Controllers
@model IEnumerable<UsersController.UserRow>
@{
    ViewData["Title"] = "Người dùng & phân quyền";
    var allRoles = (IEnumerable<string>)ViewBag.AllRoles;
}

<h2 class="mb-4">Người dùng & phân quyền</h2>

<table class="table table-hover bg-white shadow-sm align-middle">
    <thead>
        <tr><th>Họ tên</th><th>Email</th><th>SĐT</th><th>Vai trò hiện tại</th><th>Đổi vai trò</th><th>Trạng thái</th></tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.User.FullName</td>
                <td>@row.User.Email</td>
                <td>@row.User.PhoneNumber</td>
                <td>
                    @foreach (var r in row.Roles)
                    {
                        <span class="badge bg-primary me-1">@r</span>
                    }
                    @if (!row.Roles.Any())
                    {
                        <span class="badge bg-secondary">Chưa có vai trò</span>
                    }
                </td>
                <td>
                    <form asp-action="SetRole" method="post" class="d-flex gap-2">
                        <input type="hidden" name="userId" value="@row.User.Id" />
                        <select name="role" class="form-select form-select-sm">
                            @foreach (var r in allRoles)
                            {
                                <option value="@r" selected="@(row.Roles.Contains(r))">@r</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-outline-primary">Cập nhật</button>
                    </form>
                </td>
                <td>
                    <form asp-action="ToggleActive" method="post">
                        <input type="hidden" name="userId" value="@row.User.Id" />
                        @if (row.User.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger">Khoá</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-success">Mở khoá</button>
                        }
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
